"""
Smart Room IoT - Genetic Algorithm Optimization
Optimize AC and Lamp settings using evolutionary approach
"""

import random
from fitness import calculate_fitness, TEMP_MIN, TEMP_MAX, FAN_MIN, FAN_MAX, BRIGHTNESS_MIN, BRIGHTNESS_MAX

class GeneticAlgorithm:
    """
    Genetic Algorithm for Smart Room optimization
    
    Parameters:
    - population_size: Number of individuals in population (default: 20)
    - generations: Number of generations to evolve (default: 50)
    - mutation_rate: Probability of mutation (default: 0.1)
    - crossover_rate: Probability of crossover (default: 0.7)
    - elitism: Keep best individual (default: True)
    """
    
    def __init__(self, population_size=20, generations=50, 
                 mutation_rate=0.1, crossover_rate=0.7, elitism=True):
        self.population_size = population_size
        self.generations = generations
        self.mutation_rate = mutation_rate
        self.crossover_rate = crossover_rate
        self.elitism = elitism
        
        self.best_solution = None
        self.best_fitness = 0
        self.fitness_history = []
        self.generation_stats = []
    
    def create_individual(self):
        """Create random individual [temp, fan, brightness]"""
        return [
            random.randint(TEMP_MIN, TEMP_MAX),
            random.randint(FAN_MIN, FAN_MAX),
            random.randint(BRIGHTNESS_MIN, BRIGHTNESS_MAX)
        ]
    
    def create_population(self):
        """Create initial population"""
        return [self.create_individual() for _ in range(self.population_size)]
    
    def evaluate_population(self, population):
        """Calculate fitness for all individuals"""
        return [calculate_fitness(*individual) for individual in population]
    
    def selection_tournament(self, population, fitness_scores, tournament_size=3):
        """Tournament selection - pick N random, choose best"""
        selected = []
        for _ in range(len(population)):
            # Pick random tournament contestants
            contestants = random.sample(range(len(population)), tournament_size)
            # Find best contestant
            best_idx = max(contestants, key=lambda i: fitness_scores[i])
            selected.append(population[best_idx][:])
        return selected
    
    def selection_roulette(self, population, fitness_scores):
        """Roulette wheel selection - probability based on fitness"""
        # Ensure all fitness scores are positive
        min_fitness = min(fitness_scores)
        if min_fitness < 0:
            adjusted_scores = [f - min_fitness + 1 for f in fitness_scores]
        else:
            adjusted_scores = fitness_scores
        
        total_fitness = sum(adjusted_scores)
        if total_fitness == 0:
            # If all zero, random selection
            return random.choices(population, k=len(population))
        
        # Calculate probabilities
        probabilities = [f / total_fitness for f in adjusted_scores]
        
        # Select based on probability
        selected = random.choices(population, weights=probabilities, k=len(population))
        return [ind[:] for ind in selected]
    
    def crossover_single_point(self, parent1, parent2):
        """Single-point crossover"""
        if random.random() < self.crossover_rate:
            point = random.randint(1, 2)  # Cut point (1 or 2)
            child1 = parent1[:point] + parent2[point:]
            child2 = parent2[:point] + parent1[point:]
            return child1, child2
        return parent1[:], parent2[:]
    
    def crossover_uniform(self, parent1, parent2):
        """Uniform crossover - each gene randomly from either parent"""
        if random.random() < self.crossover_rate:
            child1 = []
            child2 = []
            for i in range(len(parent1)):
                if random.random() < 0.5:
                    child1.append(parent1[i])
                    child2.append(parent2[i])
                else:
                    child1.append(parent2[i])
                    child2.append(parent1[i])
            return child1, child2
        return parent1[:], parent2[:]
    
    def mutate(self, individual):
        """Random mutation with bounds checking"""
        mutated = individual[:]
        for i in range(len(mutated)):
            if random.random() < self.mutation_rate:
                if i == 0:  # Temperature
                    mutated[i] = random.randint(TEMP_MIN, TEMP_MAX)
                elif i == 1:  # Fan speed
                    mutated[i] = random.randint(FAN_MIN, FAN_MAX)
                elif i == 2:  # Brightness
                    mutated[i] = random.randint(BRIGHTNESS_MIN, BRIGHTNESS_MAX)
        return mutated
    
    def optimize(self, verbose=True, selection_method='tournament'):
        """
        Run genetic algorithm optimization
        
        Parameters:
        - verbose: Print progress (default: True)
        - selection_method: 'tournament' or 'roulette' (default: 'tournament')
        
        Returns:
        - best_solution: [temp, fan, brightness]
        - best_fitness: fitness score
        """
        if verbose:
            print("\n" + "="*70)
            print("🧬 GENETIC ALGORITHM OPTIMIZATION STARTED")
            print("="*70)
            print(f"Population Size: {self.population_size}")
            print(f"Generations: {self.generations}")
            print(f"Mutation Rate: {self.mutation_rate}")
            print(f"Crossover Rate: {self.crossover_rate}")
            print(f"Selection Method: {selection_method}")
            print(f"Elitism: {self.elitism}")
            
            from fitness import get_current_conditions
            conditions = get_current_conditions()
            print(f"\nCurrent Conditions:")
            print(f"  - Room Temp: {conditions['temperature']}°C")
            print(f"  - Humidity: {conditions['humidity']}%")
            print(f"  - Person Detected: {conditions['person_detected']}")
            print(f"  - Lux: {conditions['lux']}")
            print("="*70 + "\n")
        
        # Initialize population
        population = self.create_population()
        
        for generation in range(self.generations):
            # Evaluate fitness
            fitness_scores = self.evaluate_population(population)
            
            # Track best solution
            max_fitness_idx = fitness_scores.index(max(fitness_scores))
            if fitness_scores[max_fitness_idx] > self.best_fitness:
                self.best_fitness = fitness_scores[max_fitness_idx]
                self.best_solution = population[max_fitness_idx][:]
            
            # Store statistics
            avg_fitness = sum(fitness_scores) / len(fitness_scores)
            min_fitness = min(fitness_scores)
            self.fitness_history.append(self.best_fitness)
            self.generation_stats.append({
                'generation': generation + 1,
                'best': self.best_fitness,
                'avg': avg_fitness,
                'min': min_fitness
            })
            
            # Print progress
            if verbose and (generation + 1) % 10 == 0:
                print(f"Gen {generation+1:3d} | "
                      f"Best: {self.best_fitness:6.2f} | "
                      f"Avg: {avg_fitness:6.2f} | "
                      f"Min: {min_fitness:6.2f} | "
                      f"Solution: AC={self.best_solution[0]}°C, "
                      f"Fan={self.best_solution[1]}, "
                      f"Brightness={self.best_solution[2]}%")
            
            # Create next generation
            if selection_method == 'tournament':
                selected = self.selection_tournament(population, fitness_scores)
            else:
                selected = self.selection_roulette(population, fitness_scores)
            
            next_population = []
            
            # Crossover and mutation
            for i in range(0, len(selected), 2):
                if i + 1 < len(selected):
                    child1, child2 = self.crossover_single_point(selected[i], selected[i+1])
                    next_population.append(self.mutate(child1))
                    next_population.append(self.mutate(child2))
            
            # Elitism: Keep best individual
            if self.elitism and self.best_solution is not None:
                next_population[0] = self.best_solution[:]
            
            population = next_population
        
        if verbose:
            print("\n" + "="*70)
            print("✅ GENETIC ALGORITHM COMPLETED!")
            print("="*70)
            print(f"Best Fitness: {self.best_fitness:.2f}")
            print(f"Best Solution:")
            print(f"  - AC Temperature: {self.best_solution[0]}°C")
            print(f"  - Fan Speed: {self.best_solution[1]}")
            print(f"  - Lamp Brightness: {self.best_solution[2]}%")
            print("="*70 + "\n")
        
        return self.best_solution, self.best_fitness
    
    def get_statistics(self):
        """Return optimization statistics"""
        return {
            'fitness_history': self.fitness_history,
            'generation_stats': self.generation_stats,
            'best_solution': self.best_solution,
            'best_fitness': self.best_fitness
        }

# ==================== STANDALONE TEST ====================
if __name__ == '__main__':
    print("\n🧬 Testing Genetic Algorithm")
    print("="*70)
    
    # Test with default parameters
    ga = GeneticAlgorithm(
        population_size=20,
        generations=50,
        mutation_rate=0.1,
        crossover_rate=0.7
    )
    
    solution, fitness = ga.optimize(verbose=True)
    
    print(f"\n📊 Final Results:")
    print(f"Solution: AC={solution[0]}°C, Fan={solution[1]}, Brightness={solution[2]}%")
    print(f"Fitness: {fitness:.2f}")
    
    stats = ga.get_statistics()
    print(f"\n📈 Convergence:")
    print(f"Initial Best: {stats['fitness_history'][0]:.2f}")
    print(f"Final Best: {stats['fitness_history'][-1]:.2f}")
    print(f"Improvement: {stats['fitness_history'][-1] - stats['fitness_history'][0]:.2f}")
