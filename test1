"""
Smart Room IoT - Particle Swarm Optimization
Optimize AC and Lamp settings using swarm intelligence
"""

import random
import numpy as np
from fitness import calculate_fitness, TEMP_MIN, TEMP_MAX, FAN_MIN, FAN_MAX, BRIGHTNESS_MIN, BRIGHTNESS_MAX

class ParticleSwarmOptimization:
    """
    Particle Swarm Optimization for Smart Room
    
    Parameters:
    - swarm_size: Number of particles (default: 30)
    - iterations: Number of iterations (default: 100)
    - w: Inertia weight (default: 0.7)
    - c1: Cognitive parameter - personal best (default: 1.5)
    - c2: Social parameter - global best (default: 1.5)
    """
    
    def __init__(self, swarm_size=30, iterations=100, w=0.7, c1=1.5, c2=1.5):
        self.swarm_size = swarm_size
        self.iterations = iterations
        self.w = w    # Inertia weight
        self.c1 = c1  # Cognitive parameter
        self.c2 = c2  # Social parameter
        
        self.best_solution = None
        self.best_fitness = 0
        self.fitness_history = []
        self.iteration_stats = []
    
    def initialize_swarm(self):
        """Initialize swarm with random positions and velocities"""
        positions = []
        velocities = []
        
        for _ in range(self.swarm_size):
            # Random position within bounds
            pos = [
                random.randint(TEMP_MIN, TEMP_MAX),
                random.randint(FAN_MIN, FAN_MAX),
                random.randint(BRIGHTNESS_MIN, BRIGHTNESS_MAX)
            ]
            positions.append(pos)
            
            # Random velocity (±10% of range)
            vel = [
                random.uniform(-1.4, 1.4),   # ±10% of temp range (14°C)
                random.uniform(-0.2, 0.2),   # ±10% of fan range (0.2)
                random.uniform(-10, 10)      # ±10% of brightness range (10%)
            ]
            velocities.append(vel)
        
        return positions, velocities
    
    def clip_position(self, position):
        """Ensure position stays within bounds"""
        return [
            max(TEMP_MIN, min(TEMP_MAX, int(position[0]))),
            max(FAN_MIN, min(FAN_MAX, int(position[1]))),
            max(BRIGHTNESS_MIN, min(BRIGHTNESS_MAX, int(position[2])))
        ]
    
    def clip_velocity(self, velocity, dim_idx):
        """Limit velocity to prevent overshooting"""
        if dim_idx == 0:  # Temperature
            max_vel = (TEMP_MAX - TEMP_MIN) * 0.2  # 20% of range
            return max(-max_vel, min(max_vel, velocity))
        elif dim_idx == 1:  # Fan speed
            max_vel = (FAN_MAX - FAN_MIN) * 0.3
            return max(-max_vel, min(max_vel, velocity))
        elif dim_idx == 2:  # Brightness
            max_vel = (BRIGHTNESS_MAX - BRIGHTNESS_MIN) * 0.2
            return max(-max_vel, min(max_vel, velocity))
        return velocity
    
    def optimize(self, verbose=True, adaptive_inertia=True):
        """
        Run PSO optimization
        
        Parameters:
        - verbose: Print progress (default: True)
        - adaptive_inertia: Decrease w over time (default: True)
        
        Returns:
        - best_solution: [temp, fan, brightness]
        - best_fitness: fitness score
        """
        if verbose:
            print("\n" + "="*70)
            print("🐦 PARTICLE SWARM OPTIMIZATION STARTED")
            print("="*70)
            print(f"Swarm Size: {self.swarm_size}")
            print(f"Iterations: {self.iterations}")
            print(f"Parameters: w={self.w}, c1={self.c1}, c2={self.c2}")
            print(f"Adaptive Inertia: {adaptive_inertia}")
            
            from fitness import get_current_conditions
            conditions = get_current_conditions()
            print(f"\nCurrent Conditions:")
            print(f"  - Room Temp: {conditions['temperature']}°C")
            print(f"  - Humidity: {conditions['humidity']}%")
            print(f"  - Person Detected: {conditions['person_detected']}")
            print(f"  - Lux: {conditions['lux']}")
            print("="*70 + "\n")
        
        # Initialize swarm
        positions, velocities = self.initialize_swarm()
        
        # Initialize personal best
        personal_best_positions = [pos[:] for pos in positions]
        personal_best_fitness = [calculate_fitness(*pos) for pos in positions]
        
        # Find initial global best
        global_best_idx = personal_best_fitness.index(max(personal_best_fitness))
        global_best_position = personal_best_positions[global_best_idx][:]
        global_best_fitness = personal_best_fitness[global_best_idx]
        
        # Main PSO loop
        for iteration in range(self.iterations):
            # Adaptive inertia weight (linearly decreasing)
            if adaptive_inertia:
                current_w = self.w - (self.w - 0.4) * (iteration / self.iterations)
            else:
                current_w = self.w
            
            # Update each particle
            for i in range(self.swarm_size):
                # Update velocity for each dimension
                r1, r2 = random.random(), random.random()
                
                for d in range(3):  # 3 dimensions: temp, fan, brightness
                    # Velocity update formula
                    vel_inertia = current_w * velocities[i][d]
                    vel_cognitive = self.c1 * r1 * (personal_best_positions[i][d] - positions[i][d])
                    vel_social = self.c2 * r2 * (global_best_position[d] - positions[i][d])
                    
                    velocities[i][d] = vel_inertia + vel_cognitive + vel_social
                    
                    # Clip velocity
                    velocities[i][d] = self.clip_velocity(velocities[i][d], d)
                
                # Update position
                for d in range(3):
                    positions[i][d] += velocities[i][d]
                
                # Clip position to bounds
                positions[i] = self.clip_position(positions[i])
                
                # Evaluate fitness
                fitness = calculate_fitness(*positions[i])
                
                # Update personal best
                if fitness > personal_best_fitness[i]:
                    personal_best_fitness[i] = fitness
                    personal_best_positions[i] = positions[i][:]
                
                # Update global best
                if fitness > global_best_fitness:
                    global_best_fitness = fitness
                    global_best_position = positions[i][:]
            
            # Store statistics
            avg_fitness = sum(personal_best_fitness) / len(personal_best_fitness)
            min_fitness = min(personal_best_fitness)
            self.fitness_history.append(global_best_fitness)
            self.iteration_stats.append({
                'iteration': iteration + 1,
                'best': global_best_fitness,
                'avg': avg_fitness,
                'min': min_fitness,
                'inertia': current_w
            })
            
            # Print progress
            if verbose and (iteration + 1) % 20 == 0:
                print(f"Iter {iteration+1:3d} | "
                      f"Best: {global_best_fitness:6.2f} | "
                      f"Avg: {avg_fitness:6.2f} | "
                      f"Min: {min_fitness:6.2f} | "
                      f"w={current_w:.3f} | "
                      f"Solution: AC={global_best_position[0]}°C, "
                      f"Fan={global_best_position[1]}, "
                      f"Brightness={global_best_position[2]}%")
        
        # Store final results
        self.best_solution = global_best_position
        self.best_fitness = global_best_fitness
        
        if verbose:
            print("\n" + "="*70)
            print("✅ PARTICLE SWARM OPTIMIZATION COMPLETED!")
            print("="*70)
            print(f"Best Fitness: {self.best_fitness:.2f}")
            print(f"Best Solution:")
            print(f"  - AC Temperature: {self.best_solution[0]}°C")
            print(f"  - Fan Speed: {self.best_solution[1]}")
            print(f"  - Lamp Brightness: {self.best_solution[2]}%")
            print("="*70 + "\n")
        
        return self.best_solution, self.best_fitness
    
    def get_statistics(self):
        """Return optimization statistics"""
        return {
            'fitness_history': self.fitness_history,
            'iteration_stats': self.iteration_stats,
            'best_solution': self.best_solution,
            'best_fitness': self.best_fitness
        }
    
    def get_diversity(self, positions):
        """Calculate swarm diversity (for analysis)"""
        if len(positions) < 2:
            return 0.0
        
        # Calculate average pairwise distance
        total_distance = 0
        count = 0
        
        for i in range(len(positions)):
            for j in range(i + 1, len(positions)):
                distance = sum((positions[i][d] - positions[j][d]) ** 2 for d in range(3))
                total_distance += distance ** 0.5
                count += 1
        
        return total_distance / count if count > 0 else 0.0

# ==================== STANDALONE TEST ====================
if __name__ == '__main__':
    print("\n🐦 Testing Particle Swarm Optimization")
    print("="*70)
    
    # Test with default parameters
    pso = ParticleSwarmOptimization(
        swarm_size=30,
        iterations=100,
        w=0.7,
        c1=1.5,
        c2=1.5
    )
    
    solution, fitness = pso.optimize(verbose=True, adaptive_inertia=True)
    
    print(f"\n📊 Final Results:")
    print(f"Solution: AC={solution[0]}°C, Fan={solution[1]}, Brightness={solution[2]}%")
    print(f"Fitness: {fitness:.2f}")
    
    stats = pso.get_statistics()
    print(f"\n📈 Convergence:")
    print(f"Initial Best: {stats['fitness_history'][0]:.2f}")
    print(f"Final Best: {stats['fitness_history'][-1]:.2f}")
    print(f"Improvement: {stats['fitness_history'][-1] - stats['fitness_history'][0]:.2f}")
