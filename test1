"""
Smart Room IoT - Fitness Function
Shared fitness calculation for GA and PSO
"""

# Optimization bounds
TEMP_MIN, TEMP_MAX = 16, 30      # AC temperature range (°C)
FAN_MIN, FAN_MAX = 1, 3          # Fan speed levels
BRIGHTNESS_MIN, BRIGHTNESS_MAX = 0, 100  # Lamp brightness (%)

# Current sensor data (will be updated from MQTT)
current_data = {
    'temperature': 28.0,
    'humidity': 55.0,
    'person_detected': False,
    'lux': 200
}

def calculate_fitness(temp_set, fan_speed, brightness):
    """
    Calculate fitness score based on comfort and energy efficiency
    
    Parameters:
    - temp_set: AC temperature setting (16-30°C)
    - fan_speed: Fan speed (1-3)
    - brightness: Lamp brightness (0-100%)
    
    Returns:
    - fitness: float score (higher = better)
    """
    temp_room = current_data['temperature']
    humidity = current_data['humidity']
    person_detected = current_data['person_detected']
    
    # ==================== 1. COMFORT SCORE ====================
    comfort = 0
    
    # Temperature comfort
    if person_detected:
        target_temp = 25
        ideal_range = (24, 26)
    else:
        target_temp = 28
        ideal_range = (27, 29)
    
    temp_diff = abs(temp_set - target_temp)
    if ideal_range[0] <= temp_set <= ideal_range[1]:
        comfort += 50  # Perfect temperature
    else:
        comfort += max(0, 50 - (temp_diff * 5))
    
    # Humidity comfort (40-60% is ideal)
    if 40 <= humidity <= 60:
        comfort += 20
    elif 30 <= humidity <= 70:
        comfort += 10
    
    # Brightness comfort
    if person_detected:
        if brightness >= 70:
            comfort += 20
        elif brightness >= 50:
            comfort += 10
    else:
        if brightness <= 30:
            comfort += 20
        elif brightness <= 50:
            comfort += 10
    
    # Fan speed comfort
    if temp_set < 22 and fan_speed >= 3:
        comfort -= 10  # Too cold + strong fan = uncomfortable
    
    # ==================== 2. ENERGY PENALTY ====================
    # AC power: Lower temp + Higher fan = More power
    ac_power = (30 - temp_set) * 50 + fan_speed * 30
    
    # Lamp power: 0.5W per 1% brightness
    lamp_power = brightness * 0.5
    
    # Total power consumption
    total_power = ac_power + lamp_power
    
    # Energy penalty
    energy_penalty = total_power / 10
    
    # ==================== 3. ADAPTIVE WEIGHT ====================
    if person_detected:
        comfort_weight = 1.5  # Prioritize comfort
        energy_weight = 1.0
    else:
        comfort_weight = 1.0
        energy_weight = 1.5   # Prioritize energy saving
    
    # ==================== 4. BALANCE BONUS ====================
    if ideal_range[0] <= temp_set <= ideal_range[1] and fan_speed == 2:
        comfort += 10  # Perfect balance
    
    # ==================== 5. TOTAL FITNESS ====================
    fitness = (comfort * comfort_weight) - (energy_penalty * energy_weight)
    
    return max(0, fitness)

def update_sensor_data(temperature=None, humidity=None, person_detected=None, lux=None):
    """Update current sensor readings"""
    if temperature is not None:
        current_data['temperature'] = temperature
    if humidity is not None:
        current_data['humidity'] = humidity
    if person_detected is not None:
        current_data['person_detected'] = person_detected
    if lux is not None:
        current_data['lux'] = lux

def get_current_conditions():
    """Return current sensor data"""
    return current_data.copy()
